{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AhlulBaytNotificationPayload",
  "type": "object",
  "required": ["category"],
  "properties": {
    "category": {
      "enum": ["prayer", "events", "duas", "quran", "hadith", "muharram", "amaal", "fasting", "ai"]
    },
    "route": { "type": "string" },
    "routeParams": { "type": "object", "additionalProperties": { "type": "string" } },
    "ruleId": { "type": "string" },
    "eventId": { "type": "string" },
    "duaId": { "type": "string" },
    "hadithId": { "type": "string" },
    "surah": { "type": "string" },
    "ayah": { "type": "string" },
    "scholarlyReference": {
      "type": "object",
      "properties": {
        "source": { "type": "string" },
        "bookName": { "type": "string" },
        "reference": { "type": "string" },
        "ayahNumber": { "type": "string" },
        "hadithNumber": { "type": "string" }
      }
    }
  }
}
