{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ahlulbayt.app/schemas/references.schema.json",
  "title": "IslamicReference",
  "description": "Universal scholarly reference model for AhlulBayt+ content",
  "type": "object",
  "required": ["id", "kind", "primarySource", "verification"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": [
        "quran",
        "tafsir",
        "hadith",
        "dua",
        "ziyarat",
        "fiqh",
        "calendar",
        "history",
        "amaal",
        "book",
        "scholar",
        "external"
      ]
    },
    "primarySource": { "$ref": "#/$defs/localizedText" },
    "bookName": { "$ref": "#/$defs/localizedText" },
    "volume": { "oneOf": [{ "type": "number" }, { "type": "string" }] },
    "page": { "oneOf": [{ "type": "number" }, { "type": "string" }] },
    "hadithNumber": { "type": "string" },
    "chapter": { "$ref": "#/$defs/localizedText" },
    "surah": { "type": "integer", "minimum": 1, "maximum": 114 },
    "ayah": { "type": "integer", "minimum": 1 },
    "ayahEnd": { "type": "integer", "minimum": 1 },
    "translationSource": { "$ref": "#/$defs/localizedText" },
    "tafsirSource": { "$ref": "#/$defs/localizedText" },
    "narrator": { "$ref": "#/$defs/localizedText" },
    "scholar": { "$ref": "#/$defs/localizedText" },
    "marja": {
      "type": "string",
      "enum": ["sistani", "khamenei", "shirazi", "general"]
    },
    "grading": { "$ref": "#/$defs/localizedText" },
    "url": { "type": "string", "format": "uri" },
    "contentRef": { "type": "string" },
    "verification": {
      "type": "string",
      "enum": ["verified", "pending", "unavailable"]
    },
    "notes": { "$ref": "#/$defs/localizedText" }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "quran" } } },
      "then": { "required": ["surah", "ayah"] }
    },
    {
      "if": { "properties": { "kind": { "const": "external" } } },
      "then": { "required": ["url"] }
    }
  ],
  "$defs": {
    "localizedText": {
      "type": "object",
      "required": ["en"],
      "properties": {
        "en": { "type": "string", "minLength": 1 },
        "ur": { "type": "string" },
        "ar": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
