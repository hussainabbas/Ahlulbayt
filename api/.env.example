NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://ahlulbayt:ahlulbayt@localhost:5432/ahlulbayt
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
APPLE_CLIENT_ID=com.ahlulbayt.app
APPLE_TEAM_ID=
APPLE_KEY_ID=
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
PASSWORD_RESET_EXPIRES_MINUTES=60

# Content CDN (S3/CloudFront) — bundle URLs in manifest are prefixed with this
CONTENT_CDN_BASE_URL=https://cdn.ahlulbayt.app

# AI provider: local (rule engine) | openai (future)
AI_PROVIDER=local
OPENAI_API_KEY=

# Monetization — set true in dev to skip receipt validation
MONETIZATION_DEV_MODE=true

# Default local admin — created by: npm run db:seed:admin
# Email: admin@ahlulbayt.com  Password: Ahlulbayt@512
